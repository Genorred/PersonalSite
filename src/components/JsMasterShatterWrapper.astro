---
import JsMaster from "./JsMaster.astro";
---

<div class="shatter-wrapper">
  <div class="shatter shatter-left">
    <JsMaster />
  </div>
  <div class="shatterRightWrapper">
    <div class="shatter shatter-right">
      <JsMaster />
    </div>
  </div>
</div>
<style>
  /* глубина зубцов */
  :root {
    --inset: 80%;
    --diff: 10%;
  }
  .shatter-wrapper {
    background-color: orange;
    position: relative;
    justify-items: center;
    padding: 2rem;
    max-width: 56rem;
    width: 100vw;
    /* background-color: oklch(0.145 0 0); */
    /* background-image: radial-gradient( */
    /*   ellipse 80% 80% at 50% -20%, */
    /*   rgba(120, 119, 198, 0.3), */
    /*   rgba(255, 255, 255, 0) */
    /* ); */
  }
  .shatter {
    position: absolute;
    top: 0;
  }
  /* Правильная правая половина — y-шаги: 4%,10%,16%...88%,94% */
  .shatter-right {
    --x: var(--inset);
    --left-x: max(0%, calc(var(--inset) - var(--diff)));
    left: 1px;

    clip-path: polygon(
      /* верхняя кромка */ 0 0,
      var(--left-x) 0,

      /* зубцы — используем те же y-координаты, что и в левой половине */
      var(--x) 4%,
      var(--left-x) 10%,

      var(--x) 16%,
      var(--left-x) 22%,

      var(--x) 28%,
      var(--left-x) 34%,

      var(--x) 40%,
      var(--left-x) 46%,

      var(--x) 52%,
      var(--left-x) 58%,

      var(--x) 64%,
      var(--left-x) 70%,

      var(--x) 76%,
      var(--left-x) 82%,

      var(--x) 88%,
      var(--left-x) 94%,

      /* низ */ 100% 100%,
      0 100%
    );
  }

  /* Левая половина — те же y-шаги, но зеркально (идём сверху вниз к низу) */
  .shatter-left {
    --x: var(--inset);
    --left-x: max(0%, calc(var(--inset) - var(--diff)));
    left: 0;

    clip-path: polygon(
      /* верх/правый край */ 0 0,
      100% 0,
      100% 100%,
      0 100%,

      /* зубцы — зеркальное перечисление тех же y-координат (от низа к верху или в порядке,
       обеспечивающем корректное замыкание полигона) */
      var(--left-x) 94%,
      var(--x) 88%,

      var(--left-x) 82%,
      var(--x) 76%,

      var(--left-x) 70%,
      var(--x) 64%,

      var(--left-x) 58%,
      var(--x) 52%,

      var(--left-x) 46%,
      var(--x) 40%,

      var(--left-x) 34%,
      var(--x) 28%,

      var(--left-x) 22%,
      var(--x) 16%,

      var(--left-x) 10%,
      var(--x) 4%,

      /* завершающая точка (на верхней линии) */ var(--left-x) 0
    );

    perspective-origin: 100% 50%;
    animation: slideLeft 1s 2s ease-out;
  }
  .shatterRightWrapper {
    perspective-origin: -100% 50%;
    animation: slide 1s 2s ease-out;
    left: 0;
    position: absolute;
    top: 0;
  }
  @keyframes slideLeft {
    from {
      left: 5%;
      transform: perspective(5000px) rotate3d(0, 1, 0, -30deg);
      /* filter: drop-shadow(1px 0px 0px white); */
    }
    to {
      transform: perspective(5000px) rotate3d(0, 1, 0, -45deg);
      left: 20%;
      /* filter: drop-shadow(1px 0px 0px white); */
    }
  }
  @keyframes slide {
    from {
      left: -1%;
      transform: perspective(2500px) rotate3d(0, 1, 0, 5deg);
      /* filter: drop-shadow(1px 0px 0px white); */
    }
    to {
      transform: perspective(2500px) rotate3d(0, 1, 0, 10deg);
      left: -1%;
      /* filter: drop-shadow(1px 0px 0px white); */
    }
  }
</style>
